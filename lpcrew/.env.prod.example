# Скопируй в .env на сервере и заполни. Файл .env в git НЕ коммитим.

# --- Django ---
DJANGO_SETTINGS_MODULE=lpcrew.settings.prod
# Сгенерируй: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string

# Демо по IP без домена/TLS → 0. Появится домен+сертификат → 1.
ENABLE_SSL=0

# IP сервера (и домен, когда будет). Через запятую, без пробелов.
ALLOWED_HOSTS=123.45.67.89,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://123.45.67.89

# Базовый URL для админки Wagtail (ссылки в письмах/превью)
WAGTAILADMIN_BASE_URL=http://123.45.67.89

# --- PostgreSQL (prod БД, данные в volume lpcrew_pgdata) ---
POSTGRES_DB=lpcrew
POSTGRES_USER=lpcrew
# ОБЯЗАТЕЛЬНО смени на длинный случайный пароль
POSTGRES_PASSWORD=change-me-strong-password

# --- Суперпользователь (создаётся при первом старте) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-strong-admin-pass
DJANGO_SUPERUSER_EMAIL=admin@example.com

# --- Уведомления о заявках (опционально) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Почта (опционально) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
